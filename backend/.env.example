# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Banco PostgreSQL (Render)
DATABASE_URL=postgresql://user:password@host/database

# Google OAuth (criar em console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT Secret (qualquer string aleatoria longa)
JWT_SECRET=

# URL do frontend (para redirect do OAuth)
FRONTEND_URL=http://localhost:3000

# Qwen VL (DashScope — OCR camada 1, mais barato que Gemini)
# Obter em: https://modelstudio.console.alibabacloud.com → Key Management
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Configuracoes
FLASK_ENV=development
FLASK_PORT=5000
