# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Banco PostgreSQL (Render)
DATABASE_URL=postgresql://user:password@host/database

# Google OAuth (criar em console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT Secret (qualquer string aleatoria longa)
JWT_SECRET=

# URL do frontend (para redirect do OAuth)
FRONTEND_URL=http://localhost:3000

# Qwen VL (DashScope — OCR camada 1, mais barato que Gemini)
# Obter em: https://modelstudio.console.alibabacloud.com → Key Management
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Configuracoes
FLASK_ENV=development
FLASK_PORT=5000

# ============================================================================
# Winegod Data Ops - Control Plane (Fase 1)
# ============================================================================
# Tokens (nunca commitar valores reais)
OPS_TOKEN=
OPS_DASHBOARD_TOKEN=

# Feature flags (defaults seguros)
OPS_API_ENABLED=true
OPS_WRITE_ENABLED=true
OPS_DASHBOARD_ENABLED=false
OPS_ALERTS_ENABLED=false
OPS_CANARY_ENABLED=true
OPS_DEBUG_KEEP_SAMPLE=false
OPS_RETENTION_BATCH_SIZE=10000

# Banco local para testes/canario Fase 1 (opcional)
# Se definido com host localhost/127.0.0.1, testes rodam migration real.
# Se nao definido ou apontar para Render, testes de DB sao skipped.
OPS_TEST_DATABASE_URL=
OPS_LOCAL_DATABASE_URL=

# Dashboard Fase 3 (HTML /ops) - em producao setar valores aleatorios
# fortes. OPS_DASHBOARD_ENABLED controla se as rotas UI respondem.
# OPS_DASHBOARD_TOKEN e comparado via hmac.compare_digest.
# OPS_SESSION_SECRET assina cookies de sessao do Flask.
OPS_DASHBOARD_TOKEN=
OPS_SESSION_SECRET=
